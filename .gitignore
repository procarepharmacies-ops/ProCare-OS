# Secrets / local config — NEVER commit
config/connections.json
*.env
.env*
!.env.example
!.env.local.example
secrets/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / frontend
node_modules/
.next/
dist/
build/
*.local

# Editors / OS / local run config (launch.json holds machine-specific paths)
.vscode/
.idea/
# Keep local Claude config out of git, but DO track shared skills (e.g. the
# Firecrawl CLI skill) so every checkout gets them.
.claude/*
!.claude/skills/
!.claude/skills/**
.DS_Store
Thumbs.db

# Firecrawl CLI: scrape/crawl output cache + any local auth/config it drops in
# the working tree (credentials really live in the home dir — never commit them).
.firecrawl/

# Data / backups / large binaries (keep the repo lean)
*.bak
*.bacpac
*.mdf
*.ldf
*.zip
*.exe
*.pdf
*.png
!src/frontend/public/logo.png
!src/frontend/app/icon.png
data/
exports/
logs/
*.log

# DirectX / Visual C++ redistributable .cab files (dropped into repo root by
# Windows SDK installers) — not source, never commit.
*.cab
APR2007_*/
DEC2006_*/
vcredist_*.exe
*.msi
DSETUP*.dll
dsetup*.dll

# Local (no-Docker) launcher runtime state
.local-run/
*.pid
