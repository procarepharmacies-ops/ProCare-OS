# Backend dev settings only. Real DB secrets live in config/connections.json
# (git-ignored), NOT here.
PROCARE_API_PORT=8000

# Optional: the Arabic AI assistant uses the Claude API when this is set.
# Without it, the assistant falls back to a deterministic keyword router, so the
# stack still runs fully offline. The env var NAME is configurable in
# config/connections.json -> ai.api_key_env (default ANTHROPIC_API_KEY).
# ANTHROPIC_API_KEY=sk-ant-...
