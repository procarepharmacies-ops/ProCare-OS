# Live eStock connection for the sync overlay (deploy/docker-compose.estock-live.yml).
#
#   cp deploy/estock.env.example deploy/estock.env   # estock.env is git-ignored
#   edit deploy/estock.env with the real values, then run the overlay.
#
# Use a DEDICATED READ-ONLY SQL login — ProCare only ever reads eStock.

# Address of the eStock SQL Server. May be a LAN IP or a PUBLIC static IP
# (the production server is remote, reached over the internet on 1433).
ESTOCK_HOST=__server_ip_or_host__
ESTOCK_PORT=1433

# eStock database name (the audit shows it is "stock").
ESTOCK_DB=stock

# Read-only SQL Server login.
ESTOCK_USER=readonly_user
ESTOCK_PASSWORD=__put_password_here__

# eStock store_id -> ProCare branch code (owner-confirmed: store_id 1 = Elsanta).
# Add the store_id for any other branch (e.g. Mashal) to name it; any store_id
# you DON'T list is still synced — the ETL auto-creates a branch "STORE<id>" for
# it, so no branch's data is ever merged into another.
ESTOCK_STORE_BRANCH_MAP={"1":"ELSANTA","2":"MAIN"}

# How often to mirror (seconds).
SYNC_INTERVAL_SECONDS=15
