# ProCare OS — example environment file.
# Copy to `.env` (git-ignored) and fill in as needed. All keys are OPTIONAL:
# the stack runs seeded/offline with none of them set.

# --- Firecrawl CLI (web scraping) -------------------------------------------
# Alternative to `firecrawl login`; see docs/09-firecrawl-cli.md.
# FIRECRAWL_API_KEY=fc-xxxxxxxx
# FIRECRAWL_API_URL=            # only for a self-hosted Firecrawl instance
# FIRECRAWL_NO_TELEMETRY=1      # opt out of Firecrawl usage telemetry

# --- AI assistant ------------------------------------------------------------
# ANTHROPIC_API_KEY=

# --- eStock continuous sync --------------------------------------------------
# SYNC_ENABLED=0               # 1 = mirror the real eStock DB in the background
# SYNC_INTERVAL_SECONDS=30

# --- Automation / operations (scheduler) ------------------------------------
# AUTOMATION_ENABLED=0         # 1 = run scheduled jobs (digest, db-health, …)
# BRANCH_TIMEZONE=             # IANA name, e.g. Africa/Cairo (08:00 CEO digest)
# DB_SIZE_CAP_MB=10240         # SQL Server Express 10 GB cap for db-health alerts

# --- WhatsApp manager alerts (Meta Cloud API) -------------------------------
# MANAGER_PHONE=
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
